# Skywatch configuration — copy to .env and adjust.
# Skywatch loads .env at startup to fill in anything not already set in the
# environment (already-set variables win, so `PORT=9000 make run` overrides
# this file). `make test` needs no configuration and no network. Real values
# live only in .env, which is git-ignored.

# Observer location in decimal degrees. Required.
# LATITUDE:  -90 to 90 (north positive). LONGITUDE: -180 to 180 (east positive).
LATITUDE=47.61
LONGITUDE=-122.33

# Port for the local status page and health endpoint. Optional, default 8000.
# The server always binds 127.0.0.1 (loopback) only.
PORT=8000

# SQLite database file (created on first run). Optional, default skywatch.db.
DB_PATH=skywatch.db

# Verdict thresholds. Optional. A pass is GO when its worst overlapping
# forecast hour is <= CLOUD_GO_MAX percent cloud, MAYBE up to CLOUD_MAYBE_MAX,
# SKIP beyond; passes peaking below MIN_ELEVATION_DEG degrees are skipped.
CLOUD_GO_MAX=30
CLOUD_MAYBE_MAX=70
MIN_ELEVATION_DEG=25

# Email digest over SMTP. Leave SMTP_HOST unset to disable the digest.
# The defaults target a LOCAL inbox (Mailpit: `mailpit` then open
# http://localhost:8025) — sending real mail is a deliberate act: point
# SMTP_HOST/SMTP_PORT at a real server and usually set SMTP_STARTTLS=yes
# plus SMTP_USER/SMTP_PASSWORD. Secrets live only here, never in tracked files.
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_TO=you@example.org
SMTP_FROM=skywatch@localhost
#SMTP_USER=
#SMTP_PASSWORD=
SMTP_STARTTLS=no

# Scheduler: minutes between fetch/verdict/digest cycles (5-1440).
# One cycle also runs immediately at startup; trigger one any time with
# `make cycle` or `curl -X POST http://127.0.0.1:8000/cycle`.
FETCH_INTERVAL_MINUTES=360

# Days of history to keep; each cycle prunes rows older than this (1-3650).
RETENTION_DAYS=30

# Local window during which no digest is emailed (fetching continues and the
# email waits for the window to end, or for a later pass). May cross midnight.
# Unset (the default) means digests can go out at any hour.
#QUIET_HOURS=22:00-08:00

# Testing-only: point the sources at a local fixture server (see
# docs/specs/config.md). Leave unset for the real upstreams.
#PASSES_BASE_URL=
#FORECAST_BASE_URL=
