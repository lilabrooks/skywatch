# Skywatch configuration — copy to .env and adjust.
# `make run` sources .env automatically; `make test` needs no configuration
# and no network. Real values live only in .env, which is git-ignored.

# Observer location in decimal degrees. Required.
# LATITUDE:  -90 to 90 (north positive). LONGITUDE: -180 to 180 (east positive).
LATITUDE=47.61
LONGITUDE=-122.33

# Port for the local status page and health endpoint. Optional, default 8000.
# The server always binds 127.0.0.1 (loopback) only.
PORT=8000

# SQLite database file (created on first run). Optional, default skywatch.db.
DB_PATH=skywatch.db
